{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "my-first-flue-agent",
  "account_id": "e2d9809af7ce19ddf69f0ba687e678ac",
  "compatibility_date": "2026-06-01",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "ai": {
    "binding": "AI",
    "remote": true
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["FlueRegistry", "FlueHelloWorldAgent"] },
    { "tag": "v2", "new_sqlite_classes": ["FlueCalculatorAgent", "FlueRouterAgent"] },
    { "tag": "v3", "new_sqlite_classes": ["FlueDataCleanerAgent"] },
    {
      "tag": "v4",
      "new_sqlite_classes": [
        "DemoJsonStore",
        "FlueCodeModeAgent",
        "FlueWorkspaceAgent",
        "FlueHybridDataCleanerAgent",
        "FlueWebExtractorAgent",
        "FlueDocsRagAgent",
        "FlueEmailProcessorAgent",
        "FlueMemoryDispatcherAgent",
        "FlueRepeatableReportWorkflow"
      ]
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "DEMO_JSON_STORE",
        "class_name": "DemoJsonStore"
      }
    ]
  }
}
